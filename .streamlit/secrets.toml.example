# Streamlit Cloud secrets 配置示例
# 部署到 https://share.streamlit.io 时,在 App Settings → Secrets 粘这份(去掉注释)

# 火山方舟 / 即梦 4.6 + Doubao 文本，复用同一把 key
ARK_API_KEY = "ark-xxxxxxxx-xxxxxxxx-xxxxxxxx"

# 即梦图生成模型
JIMENG_MODEL = "doubao-seedream-4-5-251128"

# Doubao 文本模型 endpoint id（建议在火山方舟创建独立接入点后填实际 id）
DOUBAO_MODEL = "doubao-1-5-pro-32k-250115"

# Streamlit Cloud 出公网调即梦超时较短，建议 web 上跑时强制 mock 图片，把审核通过的内容下载到本地真正生图
MOCK_IMAGES = "true"
MOCK_AI_EXTRACT = "false"
