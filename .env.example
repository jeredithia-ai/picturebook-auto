# 火山方舟 / 即梦 4.6 API Key（控制台→推理接入点→API Key）
# https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
JIMENG_API_KEY=
# 备选别名（二选一；如果只配一把 key，所有调用都走它）
# ARK_API_KEY=

# 即梦模型 ID（控制台开通 Seedream 4.6 后填实际 ID）
JIMENG_MODEL=doubao-seedream-4-5-251128
JIMENG_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 输出尺寸（4:3）
IMAGE_SIZE=2304x1728
IMAGE_WATERMARK=false

# Doubao 文本模型（v1.4 新增 — Web App AI 抽词/拆段/出题用）
# 火山方舟控制台「在线推理」→「自定义推理接入点」拿到 endpoint id（如 ep-2026xxxxx-xxxxx）
DOUBAO_API_KEY=
DOUBAO_MODEL=doubao-1-5-pro-32k-250115
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 调试用：true=不调 API，生成占位图 / 走规则 mock
MOCK_IMAGES=false
MOCK_AI_EXTRACT=false

# 网络请求
REQUEST_TIMEOUT=240
REQUEST_RETRIES=2
